<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CalBudget" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="windowSplashScreenBackground">#FFDD00</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.CalBudget.Main</item>
    </style>

    <style name="Theme.CalBudget.Main" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>